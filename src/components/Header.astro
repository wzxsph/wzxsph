---
import ArrowIcon from "./ArrowIcon.astro";
import { GITHUB, homeCopy, homePath, withBase, type Lang } from "../data/site";

interface Props {
  lang: Lang;
  translationPath: string;
}

const { lang, translationPath } = Astro.props;
const copy = homeCopy[lang].nav;
const home = homePath(lang);
---

<header class="site-header">
  <div class="header-inner">
    <a class="wordmark" href={home} aria-label={lang === "zh" ? "宋品豪首页" : "Pinhao Song home"}>Pinhao Song</a>

    <nav class="desktop-nav" aria-label={lang === "zh" ? "主导航" : "Primary navigation"}>
      <a href={homePath(lang, "#work")}>{copy.work}</a>
      <a href={homePath(lang, "#about")}>{copy.about}</a>
      <a href={homePath(lang, "#contact")}>{copy.contact}</a>
      <a href={GITHUB} target="_blank" rel="noreferrer">GitHub <ArrowIcon direction="up-right" size={15} /></a>
      <a class="language-link" href={withBase(translationPath)} hreflang={lang === "zh" ? "en" : "zh-CN"}>{copy.language}</a>
    </nav>

    <div class="mobile-actions">
      <a class="mobile-language" href={withBase(translationPath)} hreflang={lang === "zh" ? "en" : "zh-CN"}>{copy.language}</a>
      <button class="menu-button" type="button" data-menu-open aria-haspopup="dialog" aria-controls="site-menu">
        <span>{copy.menu}</span>
        <span class="menu-lines" aria-hidden="true"><i></i><i></i></span>
      </button>
    </div>
  </div>

  <dialog id="site-menu" class="mobile-menu" data-site-menu aria-label={lang === "zh" ? "移动导航" : "Mobile navigation"}>
    <div class="menu-dialog-inner">
      <div class="menu-dialog-header">
        <a class="wordmark menu-wordmark" href={home}>Pinhao Song</a>
        <button class="menu-close" type="button" data-menu-close>
          <span>{copy.close}</span>
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none">
            <path d="m5 5 14 14M19 5 5 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>
      </div>
      <nav class="mobile-nav" aria-label={lang === "zh" ? "移动端主导航" : "Mobile primary navigation"}>
        <a href={homePath(lang, "#work")}>{copy.work}<ArrowIcon /></a>
        <a href={homePath(lang, "#about")}>{copy.about}<ArrowIcon /></a>
        <a href={homePath(lang, "#contact")}>{copy.contact}<ArrowIcon /></a>
        <a href={GITHUB} target="_blank" rel="noreferrer">GitHub<ArrowIcon direction="up-right" /></a>
        <a href={withBase(translationPath)} hreflang={lang === "zh" ? "en" : "zh-CN"}>{copy.language}<ArrowIcon /></a>
      </nav>
      <p class="menu-note">AI Product Builder · Beijing</p>
    </div>
  </dialog>
</header>

<script>
  const dialog = document.querySelector("[data-site-menu]");
  const openButton = document.querySelector("[data-menu-open]");
  const closeButton = document.querySelector("[data-menu-close]");

  if (dialog instanceof HTMLDialogElement && openButton instanceof HTMLButtonElement && closeButton instanceof HTMLButtonElement) {
    openButton.addEventListener("click", () => dialog.showModal());
    closeButton.addEventListener("click", () => dialog.close());
    dialog.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => dialog.close()));
    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
    dialog.addEventListener("close", () => openButton.focus());
  }
</script>

<style>
  .site-header {
    position: relative;
    z-index: 50;
    background: var(--paper);
  }

  .header-inner {
    width: var(--shell);
    min-height: 72px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line-strong);
  }

  .wordmark {
    color: var(--ink);
    font-size: 1.25rem;
    font-weight: 610;
    letter-spacing: -0.035em;
    text-decoration: none;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(1.35rem, 2.4vw, 2.5rem);
  }

  .desktop-nav a {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    min-height: 44px;
    color: var(--ink);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .desktop-nav a:not(.language-link) {
    background-image: linear-gradient(var(--ink), var(--ink));
    background-position: 0 84%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 180ms ease;
  }

  .desktop-nav a:hover {
    background-size: 100% 1px;
  }

  .language-link {
    padding-left: 1.5rem;
    border-left: 1px solid var(--line);
  }

  .mobile-actions { display: none; }
  .mobile-menu { display: none; }

  @media (max-width: 760px) {
    .header-inner { min-height: 66px; }
    .wordmark { font-size: 1.05rem; }
    .desktop-nav { display: none; }
    .mobile-actions { display: flex; align-items: center; gap: 0.85rem; }
    .mobile-language { color: var(--ink); font-size: 0.86rem; text-underline-offset: 0.28rem; }

    .menu-button,
    .menu-close {
      min-height: 44px;
      border: 1px solid var(--ink);
      background: transparent;
      color: var(--ink);
      font: inherit;
      cursor: pointer;
    }

    .menu-button {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0 0.85rem;
      font-size: 0.84rem;
    }

    .menu-lines { width: 16px; display: grid; gap: 4px; }
    .menu-lines i { display: block; width: 100%; height: 1px; background: currentColor; }

    .mobile-menu[open] {
      position: fixed;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      max-width: none;
      max-height: none;
      margin: 0;
      padding: 0;
      border: 0;
      background: var(--ink);
      color: var(--paper);
    }

    .mobile-menu::backdrop { background: rgba(23, 23, 23, 0.35); }
    .menu-dialog-inner { min-height: 100dvh; width: min(100% - 2rem, 42rem); margin: 0 auto; display: flex; flex-direction: column; }
    .menu-dialog-header { min-height: 66px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(244, 241, 232, 0.3); }
    .menu-wordmark { color: var(--paper); }
    .menu-close { display: inline-flex; align-items: center; gap: 0.7rem; color: var(--paper); border-color: rgba(244, 241, 232, 0.55); padding: 0 0.85rem; }

    .mobile-nav { padding-top: clamp(3rem, 10vh, 6rem); }
    .mobile-nav a {
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: var(--paper);
      border-bottom: 1px solid rgba(244, 241, 232, 0.28);
      font-size: clamp(2rem, 10vw, 3.5rem);
      font-weight: 470;
      letter-spacing: -0.055em;
      text-decoration: none;
    }

    .mobile-nav a:hover { color: var(--acid); }
    .menu-note { margin-top: auto; padding: 2rem 0; color: rgba(244, 241, 232, 0.62); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; }
  }
</style>
